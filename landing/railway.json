{
  "build": {
    "dockerfile": "Dockerfile",
    "builder": "DOCKERFILE"
  },
  "deploy": {
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5,
    "healthcheckPath": "/health",
    "healthcheckTimeout": 30,
    "healthcheckInterval": 10,
    "numReplicas": 1,
    "startCommand": "sh -c 'npm run start'"
  }
}